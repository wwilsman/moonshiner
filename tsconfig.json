{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationDir": "types",
    "skipLibCheck": true,
    "moduleResolution": "node"
  },
  "include": [
    "lib/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "types"
  ]
}
